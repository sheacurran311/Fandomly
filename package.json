{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:ui": "npx vitest --ui",
    "test:coverage": "npx vitest run --coverage",
    "test:unit": "npx vitest run tests/unit",
    "test:api": "npx vitest run tests/api",
    "test:api:admin": "npx vitest run tests/api/admin",
    "test:privacy": "npx vitest run tests/privacy",
    "test:e2e": "node scripts/playwright-smoke.mjs",
    "test:e2e:admin": "PW_STORAGE=playwright-admin-auth.json node scripts/playwright-admin-smoke.mjs",
    "test:social": "tsx scripts/social-api-test.ts",
    "test:all": "npm run test && npm run test:e2e",
    "db:push": "drizzle-kit push",
    "create-admin": "tsx scripts/create-admin.ts",
    "list-admins": "tsx scripts/list-admins.ts",
    "link-admin": "tsx scripts/link-dynamic-to-admin.ts",
    "promote-admin": "tsx scripts/promote-to-admin.ts",
    "validate-imports": "tsx scripts/validate-imports.ts",
    "test-endpoints": "tsx scripts/test-api-endpoints.ts",
    "verify-build": "npm run validate-imports && npm run test-endpoints",
    "smoke:pw:login": "node scripts/playwright-login.mjs",
    "smoke:pw": "node scripts/playwright-smoke.mjs",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "client/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "server/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "shared/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
